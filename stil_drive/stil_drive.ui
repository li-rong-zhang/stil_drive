<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>stil_driveClass</class>
 <widget class="QMainWindow" name="stil_driveClass">
  <property name="geometry">
   <rect><x>0</x><y>0</y><width>1280</width><height>720</height></rect>
  </property>
  <property name="windowTitle">
   <string>stil_drive — 轨迹规划与同步采集</string>
  </property>
  <widget class="QWidget" name="centralWidget">
   <layout class="QVBoxLayout" name="centralLayout">
    <item>
     <widget class="QCustomPlot" name="plot_Widget" native="true"/>
    </item>
    <item>
     <layout class="QHBoxLayout" name="ctrlRow">
      <item>
       <widget class="QPushButton" name="btn_Start">
        <property name="text"><string>开始采集</string></property>
        <property name="toolTip"><string>快速启动：信任脚本预览中的当前脚本，跳过参数校验直接下发并采集（用于脚本手动微调后重跑）。</string></property>
       </widget>
      </item>
      <item>
       <widget class="QPushButton" name="btn_Stop">
        <property name="text"><string>停止采集</string></property>
        <property name="toolTip"><string>停止采集线程并下发急停脚本（关闭 EQU 触发使能）。</string></property>
       </widget>
      </item>
      <item>
       <widget class="QCheckBox" name="chk_SaveData">
        <property name="text"><string>同时保存数据到 CSV</string></property>
       </widget>
      </item>
      <item>
       <spacer name="hsp"><property name="orientation"><enum>Qt::Horizontal</enum></property></spacer>
      </item>
     </layout>
    </item>
   </layout>
  </widget>
  <widget class="QMenuBar" name="menuBar">
   <property name="geometry"><rect><x>0</x><y>0</y><width>1280</width><height>22</height></rect></property>
   <widget class="QMenu" name="menu_File">
    <property name="title"><string>文件</string></property>
    <addaction name="act_Exit"/>
   </widget>
   <widget class="QMenu" name="menu_Device">
    <property name="title"><string>设备</string></property>
    <addaction name="act_ConnectSensor"/>
    <addaction name="act_DisconnectSensor"/>
    <addaction name="separator"/>
    <addaction name="act_ConnectPmac"/>
    <addaction name="act_DisconnectPmac"/>
    <addaction name="act_SendCmd"/>
    <addaction name="separator"/>
    <addaction name="act_AxisMapping"/>
   </widget>
   <widget class="QMenu" name="menu_Mode">
    <property name="title"><string>测量模式</string></property>
    <addaction name="act_ModeLinear"/>
    <addaction name="act_ModeSpiral"/>
    <addaction name="act_ModeSpherical"/>
    <addaction name="act_ModeAspheric"/>
   </widget>
   <widget class="QMenu" name="menu_View">
    <property name="title"><string>视图</string></property>
    <addaction name="act_ShowPlanner"/>
    <addaction name="act_ShowScript"/>
    <addaction name="act_ShowLog"/>
   </widget>
   <widget class="QMenu" name="menu_Tools">
    <property name="title"><string>工具</string></property>
    <addaction name="act_GenerateScript"/>
    <addaction name="act_EmergencyStop"/>
    <addaction name="separator"/>
    <addaction name="act_Analyze"/>
   </widget>
   <widget class="QMenu" name="menu_Help">
    <property name="title"><string>帮助</string></property>
    <addaction name="act_About"/>
   </widget>
   <addaction name="menu_File"/>
   <addaction name="menu_Device"/>
   <addaction name="menu_Mode"/>
   <addaction name="menu_View"/>
   <addaction name="menu_Tools"/>
   <addaction name="menu_Help"/>
  </widget>
  <widget class="QStatusBar" name="statusBar"/>
  <action name="act_Exit"><property name="text"><string>退出</string></property></action>
  <action name="act_ConnectSensor"><property name="text"><string>连接测头…</string></property></action>
  <action name="act_DisconnectSensor"><property name="text"><string>断开测头</string></property><property name="enabled"><bool>false</bool></property></action>
  <action name="act_ConnectPmac"><property name="text"><string>连接 PMAC…</string></property></action>
  <action name="act_DisconnectPmac"><property name="text"><string>断开 PMAC</string></property><property name="enabled"><bool>false</bool></property></action>
  <action name="act_SendCmd"><property name="text"><string>发送手动指令</string></property></action>
  <action name="act_AxisMapping"><property name="text"><string>轴映射配置…</string></property></action>
  <action name="act_ModeLinear"><property name="text"><string>直线扫描</string></property><property name="checkable"><bool>true</bool></property></action>
  <action name="act_ModeSpiral"><property name="text"><string>平面螺旋扫描</string></property><property name="checkable"><bool>true</bool></property></action>
  <action name="act_ModeSpherical"><property name="text"><string>球面纬线扫描</string></property><property name="checkable"><bool>true</bool></property></action>
  <action name="act_ModeAspheric"><property name="text"><string>非球面母线扫描</string></property><property name="checkable"><bool>true</bool></property></action>
  <action name="act_ShowPlanner"><property name="text"><string>显示参数面板</string></property><property name="checkable"><bool>true</bool></property><property name="checked"><bool>true</bool></property></action>
  <action name="act_ShowScript"><property name="text"><string>显示脚本预览</string></property><property name="checkable"><bool>true</bool></property><property name="checked"><bool>true</bool></property></action>
  <action name="act_ShowLog"><property name="text"><string>显示 PMAC 日志</string></property><property name="checkable"><bool>true</bool></property><property name="checked"><bool>true</bool></property></action>
  <action name="act_GenerateScript"><property name="text"><string>生成脚本</string></property></action>
  <action name="act_EmergencyStop">
   <property name="text"><string>急停</string></property>
   <property name="shortcut"><string>Esc</string></property>
  </action>
  <action name="act_Analyze"><property name="text"><string>数据分析（加载 CSV）</string></property></action>
  <action name="act_About"><property name="text"><string>关于</string></property></action>
 </widget>
